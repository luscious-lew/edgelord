{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.nfl-fa-bot"
  },
  "deploy": {
    "startCommand": "deno run --allow-net --allow-env nfl-fa-bot.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
